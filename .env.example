# HuggingFace Inference API Token
HF_TOKEN=hf_your_token_here

# HuggingFace Inference Router (do not change)
API_BASE_URL=https://router.huggingface.co/v1

# Model for inference
MODEL_NAME=meta-llama/Llama-3.2-3B-Instruct

# Environment URL (local or HuggingFace Space)
# Local: http://localhost:7860
# HuggingFace Space: https://abhiii01-medical-triage-env.hf.space
ENV_BASE_URL=http://localhost:7860

# Default environment difficulty (easy/medium/hard)
ENV_DIFFICULTY=easy

# Use rule-based fallback when LLM fails (true/false)
USE_FALLBACK=true
